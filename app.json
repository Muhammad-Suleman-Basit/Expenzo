        "backgroundColor": "#F3EFFC"
      }
    },
    "web": {
      "favicon": "./assets/expenzo-icon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "06c46aaf-a7f8-4d4e-8066-46187c2b0193"
      }
    }
  }
}
